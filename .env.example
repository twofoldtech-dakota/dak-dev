# Site Configuration
NEXT_PUBLIC_SITE_URL=https://dak-dev.vercel.app

# Giscus Comments Configuration
# Get these values from https://giscus.app
NEXT_PUBLIC_GISCUS_REPO=twofoldtech-dakota/dak-dev
NEXT_PUBLIC_GISCUS_REPO_ID=<get from giscus.app>
NEXT_PUBLIC_GISCUS_CATEGORY=General
NEXT_PUBLIC_GISCUS_CATEGORY_ID=<get from giscus.app>

# Analytics (automatically configured by Vercel)
# No environment variables needed for @vercel/analytics

# Runnable code embeds (Codapi) — OFF by default.
# Set to "true" to enable the <RunnableSnippet> in-browser playground. This
# loads the Codapi web component and (for WASI sandboxes) relaxes the CSP.
# Read the "Runnable code embeds" note in DESIGN.md before enabling, and
# apply the documented CSP diff in next.config.ts.
NEXT_PUBLIC_ENABLE_CODAPI=false

# Newsletter (double opt-in). Provider-agnostic HTTP endpoint that accepts a
# POST with the subscriber email. Leave unset to fall back to a mailto: link.
# Example (Buttondown): https://buttondown.com/api/emails/embed-subscribe/<user>
# Whatever origin you set here must be added to the CSP connect-src in
# next.config.ts (see the NEWSLETTER_ORIGIN comment there).
NEXT_PUBLIC_NEWSLETTER_ENDPOINT=
NEXT_PUBLIC_NEWSLETTER_PROVIDER=
