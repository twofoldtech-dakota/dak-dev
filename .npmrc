# ─── Supply-chain hardening (pnpm) ───────────────────────────────────────────
# These settings reduce exposure to compromised-package / npm-worm attacks
# (e.g. the Shai-Hulud campaigns) where malicious versions are published and
# then yanked within hours-to-days.

# Cooldown: refuse any dependency version published less than 3 days ago.
# A fresh malicious release is almost always detected and unpublished inside
# this window, so we never become patient zero.
minimum-release-age=4320

# Warn if installed node_modules drift from the lockfile before running scripts.
verify-deps-before-run=warn

# Dependency lifecycle/build scripts are blocked by default in pnpm 10+.
# Only packages listed under pnpm.onlyBuiltDependencies in package.json may
# run install/build scripts. Keep that allowlist as small as possible.

# Note: --frozen-lockfile is enforced in CI and on Vercel via the install
# command (not set globally here) so local dependency additions still work.

# Reduce install noise.
fund=false
