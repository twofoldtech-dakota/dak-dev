{
  "version": "1.0.0",
  "brand": "Dakota Smith Blog",
  "updated_at": "2026-01-25",
  "validation_rules": {
    "title": {
      "min_length": 30,
      "max_length": 70,
      "must_start_with_capital": true,
      "forbidden_words": ["simple", "easy", "just", "amazing", "incredible", "seamless", "effortless"]
    },
    "excerpt": {
      "min_length": 140,
      "max_length": 160,
      "must_contain_action_verb": true
    },
    "structure": {
      "min_word_count": 500,
      "max_word_count": 3000,
      "min_headings": 3,
      "require_introduction": true,
      "require_conclusion": true
    },
    "seo": {
      "min_keywords": 3,
      "max_keywords": 7,
      "min_tags": 2,
      "max_tags": 5
    },
    "tone": {
      "forbidden_phrases": [
        "I think",
        "I believe",
        "maybe",
        "perhaps",
        "sort of",
        "kind of",
        "probably",
        "might be",
        "could be",
        "just",
        "simply",
        "basically",
        "obviously",
        "actually",
        "really",
        "very",
        "amazing",
        "incredible",
        "revolutionary",
        "game-changing",
        "best ever",
        "leverage",
        "synergy",
        "paradigm shift",
        "move the needle",
        "circle back",
        "at the end of the day",
        "seamlessly",
        "effortlessly",
        "perfect solution",
        "zero overhead",
        "no downsides"
      ],
      "preferred_phrases": [
        "Here's how",
        "The key insight is",
        "This approach",
        "Notice how",
        "Let's explore",
        "I built this by",
        "The tradeoff is",
        "This works when",
        "This breaks when",
        "I tested this in production"
      ],
      "max_passive_voice_percentage": 20,
      "max_sentence_length": 35
    },
    "code_blocks": {
      "require_language_identifier": true,
      "encourage_line_highlighting": true,
      "max_lines_without_comment": 20
    },
    "images": {
      "thumbnail": {
        "required": true,
        "width": 800,
        "height": 450
      },
      "hero": {
        "required": true,
        "width": 1600,
        "height": 900
      }
    }
  },
  "content_principles": {
    "product_is_marketing": "Every post shows what was built and how. Share working code, real decisions, and results.",
    "build_trust": "Ruthless quality. Verify code, don't oversimplify, share failures, be transparent about complexity.",
    "concise_precise": "Bottom line first. Scannable structure. Address concerns directly. Specifics over generalities.",
    "build_community": "Own mistakes. Convert feedback to content. Make knowledge portable across jobs."
  },
  "scoring": {
    "weights": {
      "technical_depth": 25,
      "voice_alignment": 25,
      "structure": 25,
      "seo_readiness": 25
    },
    "thresholds": {
      "publish_ready": 80,
      "needs_minor_edits": 60,
      "needs_major_revision": 0
    }
  },
  "prose_rubric": {
    "description": "Qualitative grading applied by an LLM-as-judge in /quality-gate, on top of the mechanical validators. Each dimension is scored 0-5 against the anchors; the weighted total normalizes to 0-100. This catches what regex cannot: weak arguments, vague evidence, missing transparency, derivative takes, and AI slop. LLM-as-judge is fallible, so the human checkpoint in /quality-gate is the final authority — the rubric informs the decision, it does not replace it.",
    "scale": {
      "0": "Absent — dimension not met at all",
      "1": "Poor — major gaps, reads as AI slop or filler",
      "2": "Weak — present but unconvincing",
      "3": "Adequate — meets the bar, unremarkable",
      "4": "Strong — clearly above average",
      "5": "Exceptional — best-in-class, link-worthy"
    },
    "dimensions": {
      "argument_structure": {
        "weight": 20,
        "asks": "Does it lead with the bottom line, progress logically, and stay scannable? Can a skimmer extract the thesis in 15 seconds?",
        "fail_below": 2
      },
      "evidence_specificity": {
        "weight": 25,
        "asks": "Are claims backed by real, specific metrics, tested code, and cited sources — not vague generalities ('improves performance')? Numbers over adjectives.",
        "fail_below": 2
      },
      "transparency": {
        "weight": 25,
        "asks": "Does it address tradeoffs, when NOT to use the approach, failure modes, and the complexity tax? This is the brand's core value.",
        "fail_below": 1,
        "hard_fail_when": "technical-advice post scores 0"
      },
      "authority_originality": {
        "weight": 15,
        "asks": "Does it offer original insight, first-person production experience, or a teardown competitors don't have — versus a derivative rehash?",
        "fail_below": 1
      },
      "clarity_flow": {
        "weight": 15,
        "asks": "Does it teach the WHY, read smoothly sentence to sentence, and avoid hedging/filler/AI cadence? Would a senior engineer respect the writing?",
        "fail_below": 2
      }
    },
    "thresholds": {
      "prose_pass": 80,
      "prose_revise": 60
    }
  },
  "content_types": {
    "general": {
      "description": "Standard blog post",
      "template": "post.mdx.template",
      "min_word_count": 500
    },
    "tutorial": {
      "description": "Step-by-step guide with code examples",
      "template": "tutorial.mdx.template",
      "min_word_count": 800,
      "require_code_blocks": true,
      "require_numbered_steps": true
    },
    "project": {
      "description": "Project showcase or case study",
      "template": "project.mdx.template",
      "min_word_count": 600,
      "require_metrics": true,
      "require_tech_stack": true
    }
  },
  "seo_strategy": {
    "keyword_requirements": {
      "primary_per_post": 1,
      "secondary_per_post_min": 3,
      "secondary_per_post_max": 5,
      "long_tail_per_post_min": 1,
      "long_tail_per_post_max": 2,
      "max_keyword_density_percent": 2.5,
      "min_keyword_density_percent": 0.5
    },
    "internal_linking": {
      "min_internal_links_per_post": 2,
      "max_internal_links_per_post": 10,
      "prefer_contextual_links": true
    },
    "topic_clusters": {
      "min_cluster_posts": 3,
      "pillar_min_word_count": 2000,
      "cluster_min_word_count": 800
    },
    "search_intent_mapping": {
      "tutorial": ["informational"],
      "project": ["informational", "commercial"],
      "general": ["informational"]
    },
    "competitor_analysis": {
      "top_results_to_analyze": 5,
      "content_angles_to_identify": 3
    }
  }
}
